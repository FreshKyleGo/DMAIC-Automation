{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LSS DMAIC Project",
  "description": "One file per Lean Six Sigma project, stored at data/projects/<slug>.json. Filename must equal <slug>.json.",
  "type": "object",
  "required": ["id", "slug", "title", "sponsor", "owner", "businessUnit", "status", "currentPhase", "startDate", "define"],
  "properties": {
    "id": { "type": "string", "description": "Stable unique identifier, e.g. proj-2026-0007" },
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$", "description": "URL-safe slug, must match the filename" },
    "title": { "type": "string" },
    "sponsor": { "type": "string", "description": "Executive sponsor, e.g. 'Jane Smith, VP Finance'" },
    "owner": { "type": "string", "description": "Project lead / Black Belt / Green Belt name" },
    "team": { "type": "array", "items": { "type": "string" } },
    "businessUnit": { "type": "string" },
    "status": { "type": "string", "enum": ["Not Started", "In Progress", "Completed", "On Hold", "Cancelled"] },
    "currentPhase": { "type": "string", "enum": ["Define", "Measure", "Analyze", "Improve", "Control"] },
    "startDate": { "type": "string", "format": "date" },
    "targetCompletionDate": { "type": ["string", "null"], "format": "date" },
    "actualCompletionDate": { "type": ["string", "null"], "format": "date" },
    "financialImpact": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["Hard Savings", "Soft Savings", "Cost Avoidance", "Revenue"] },
        "annualizedAmount": { "type": "number", "minimum": 0 },
        "currency": { "type": "string", "default": "EUR" },
        "notes": { "type": "string" }
      }
    },
    "define": {
      "type": "object",
      "description": "Charter, SIPOC, and Voice of Customer",
      "required": ["problemStatement", "goalStatement"],
      "properties": {
        "processName": { "type": "string", "description": "Name of the business process being improved, distinct from the project title" },
        "processOwnerGroup": { "type": "string", "description": "The business team/group that owns the process (e.g. 'ADC Processors'), distinct from team.processOwner (an individual project team contact)" },
        "mentor": { "type": "string", "description": "Six Sigma mentor/coach assigned to guide the project" },
        "problemStatement": { "type": "string" },
        "goalStatement": { "type": "string" },
        "scope": {
          "type": "object",
          "properties": {
            "firstProcessStep": { "type": "string", "description": "Name of the first process step in scope" },
            "lastProcessStep": { "type": "string", "description": "Name of the last process step in scope" },
            "inScope": { "type": "array", "items": { "type": "string" } },
            "outOfScope": { "type": "array", "items": { "type": "string" } }
          }
        },
        "businessCase": { "type": "string" },
        "expectedBenefits": { "type": "array", "items": { "type": "string" }, "description": "Specific expected benefit statements, e.g. cycle time, throughput, TAT" },
        "identifiedSolution": { "type": "string", "description": "Solution proposed at Charter stage, independent of improve.solutions (which tracks what was actually implemented)" },
        "addedBenefit": { "type": "string", "description": "Short highlighted quantified benefit, e.g. '23 Hours Time Savings or 0.015 FTE Savings'" },
        "assumptions": { "type": "array", "items": { "type": "string" } },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "risks": {
          "type": "array",
          "description": "Risks anticipated at kickoff/scoping, distinct from control.riskMitigation (sustaining-the-gain risk tracking)",
          "items": {
            "type": "object",
            "properties": {
              "risk": { "type": "string" },
              "mitigation": { "type": "string" }
            }
          }
        },
        "team": {
          "type": "object",
          "properties": {
            "sponsor": { "type": "string" },
            "blackBelt": { "type": "string" },
            "processOwner": { "type": "string" },
            "members": { "type": "array", "items": { "type": "string" } }
          }
        },
        "sipoc": {
          "type": "object",
          "properties": {
            "suppliers": { "type": "array", "items": { "type": "string" } },
            "inputs": { "type": "array", "items": { "type": "string" } },
            "process": { "type": "array", "items": { "type": "string" } },
            "outputs": { "type": "array", "items": { "type": "string" } },
            "customers": { "type": "array", "items": { "type": "string" } }
          }
        },
        "voc": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source": { "type": "string" },
              "need": { "type": "string" },
              "criticalToQuality": { "type": "string" }
            }
          }
        }
      }
    },
    "measure": {
      "type": "object",
      "description": "Data collection plan, baseline metrics, and value stream map",
      "properties": {
        "dataCollectionPlan": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "metric": { "type": "string" },
              "operationalDefinition": { "type": "string" },
              "dataSource": { "type": "string" },
              "sampleSize": { "type": "number" },
              "collectionPeriod": { "type": "string" }
            }
          }
        },
        "baselineMetrics": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "metric": { "type": "string" },
              "baselineValue": { "type": "number" },
              "unit": { "type": "string" }
            }
          }
        },
        "valueStreamMap": {
          "type": "object",
          "description": "Lean VA/NVA/ENVA time-value analysis; totals/percentages are computed at render time, not stored",
          "properties": {
            "timeUnit": { "type": "string", "description": "e.g. 'hours' or 'minutes' — unit used consistently across all step times in this map" },
            "steps": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "step": { "type": "string" },
                  "stepLabel": { "type": "string", "enum": ["VA", "NVA", "ENVA"] },
                  "vaTime": { "type": "number" },
                  "envaNvaTime": { "type": "number" },
                  "waitTime": { "type": "number" }
                }
              }
            }
          }
        },
        "processSigma": { "type": "number" },
        "cpk": { "type": "number" },
        "notes": { "type": "string" }
      }
    },
    "analyze": {
      "type": "object",
      "description": "Root cause analysis and findings",
      "properties": {
        "rootCauseAnalysis": {
          "type": "object",
          "properties": {
            "fishbone": {
              "type": "object",
              "properties": {
                "categories": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "category": { "type": "string", "description": "One of the 6Ms: Method, Machine, Material, Manpower, Measurement, Environment" },
                      "causes": { "type": "array", "items": { "type": "string" } }
                    }
                  }
                }
              }
            },
            "fiveWhys": {
              "type": "array",
              "description": "One entry per why-chain. whys is variable-length (observed 3-5 levels in practice, not a fixed 5) — stop once the root cause is reached.",
              "items": {
                "type": "object",
                "properties": {
                  "problem": { "type": "string" },
                  "whys": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "why": { "type": "string" },
                        "because": { "type": "string" }
                      }
                    }
                  },
                  "rootCause": { "type": "string", "description": "Optional — sometimes the root cause is just the last 'because' answer and isn't restated separately" },
                  "actions": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "pareto": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "category": { "type": "string" },
              "count": { "type": "number" }
            }
          }
        },
        "findings": { "type": "string" }
      }
    },
    "improve": {
      "type": "object",
      "description": "Solutions implemented, pilot results, and implementation/change-management checklist",
      "properties": {
        "solutions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "owner": { "type": "string" },
              "implementationDate": { "type": "string", "format": "date" }
            }
          }
        },
        "implementationChecklist": {
          "type": "array",
          "description": "Mini change-management plan per solution action item",
          "items": {
            "type": "object",
            "properties": {
              "actionItem": { "type": "string" },
              "stakeholderCommsDone": { "type": "boolean" },
              "trainingDone": { "type": "boolean" },
              "budgetPlanningDone": { "type": "boolean" },
              "detailedPlanDone": { "type": "boolean" },
              "hasAnticipatedRisk": { "type": "boolean" },
              "riskRemarks": { "type": "string" }
            }
          }
        },
        "pilotResults": {
          "type": "object",
          "properties": {
            "pilotPeriod": { "type": "string" },
            "metricsBefore": { "type": "array", "items": { "type": "object" } },
            "metricsAfter": { "type": "array", "items": { "type": "object" } },
            "summary": { "type": "string" }
          }
        }
      }
    },
    "control": {
      "type": "object",
      "description": "Control plan, risk/mitigation to sustain the gain, and final results",
      "properties": {
        "controlPlan": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "metric": { "type": "string" },
              "target": { "type": "string" },
              "frequency": { "type": "string" },
              "owner": { "type": "string" },
              "responseIfOutOfControl": { "type": "string" }
            }
          }
        },
        "riskMitigation": {
          "type": "array",
          "description": "Control-phase risk tracking to sustain the gain post-implementation, distinct from define.risks (anticipated at kickoff)",
          "items": {
            "type": "object",
            "properties": {
              "risk": { "type": "string" },
              "frequency": { "type": "string", "description": "How often this risk is checked, e.g. 'As needed', 'Monthly'" },
              "responsibility": { "type": "string", "description": "Person/role responsible for reacting to this risk" },
              "reactionPlan": { "type": "string", "description": "What to do if the risk occurs" },
              "result": { "type": "string", "description": "Optional — observed outcome when using the implemented solution" }
            }
          }
        },
        "monitoringMetrics": { "type": "array", "items": { "type": "string" } },
        "standardWorkDocs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        },
        "finalResults": {
          "type": "object",
          "properties": {
            "summary": { "type": "string" },
            "actualAnnualizedSavings": { "type": "number" },
            "cycleTimeAfter": { "type": "number" },
            "keyMetricsAfter": {
              "type": "array",
              "description": "Generalized before/after metric comparison — pair with measure.baselineMetrics by matching 'metric' name",
              "items": {
                "type": "object",
                "properties": {
                  "metric": { "type": "string" },
                  "value": { "type": "number" },
                  "unit": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
